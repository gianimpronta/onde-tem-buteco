# ============================================================
# onde-tem-buteco — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local com valores reais.
# ============================================================

# ----------------------------------------------------------
# Banco de dados (Vercel Postgres / Neon)
# Obtido no painel da Vercel: Storage > seu banco > .env.local
# ----------------------------------------------------------
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ----------------------------------------------------------
# NextAuth.js
# NEXTAUTH_SECRET: gere com `openssl rand -base64 32`
# NEXTAUTH_URL: URL base da aplicação (ex: http://localhost:3000)
# ----------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ----------------------------------------------------------
# Google OAuth
# Crie em: https://console.cloud.google.com/apis/credentials
# ----------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
